{
  "name": "washes",
  "version": "1.22.0",
  "description": "An interactive watercolor simulation for the browser, built on Curtis et al.'s 1997 SIGGRAPH paper. Three-layer fluid + pigment + paper model with Kubelka-Munk compositing, with an optional WebGL2 GPU backend.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./gpu-sim": {
      "types": "./src/washes-gpu-sim.d.ts",
      "import": "./src/washes-gpu-sim.js",
      "default": "./src/washes-gpu-sim.js"
    },
    "./timeline": {
      "types": "./src/washes-timeline.d.ts",
      "import": "./src/washes-timeline.js",
      "default": "./src/washes-timeline.js"
    },
    "./sim-core": {
      "types": "./src/washes-sim-core.d.ts",
      "import": "./src/washes-sim-core.js",
      "default": "./src/washes-sim-core.js"
    },
    "./sim-worker": {
      "import": "./src/washes-sim-worker.js",
      "default": "./src/washes-sim-worker.js"
    },
    "./worker-backend": {
      "import": "./src/washes-worker-backend.js",
      "default": "./src/washes-worker-backend.js"
    },
    "./state-codec": {
      "import": "./src/washes-state-codec.js",
      "default": "./src/washes-state-codec.js"
    }
  },
  "files": [
    "src/index.js",
    "src/index.d.ts",
    "src/washes.js",
    "src/washes.d.ts",
    "src/washes-gpu-sim.js",
    "src/washes-gpu-sim.d.ts",
    "src/washes-timeline.js",
    "src/washes-timeline.d.ts",
    "src/washes-sim-core.js",
    "src/washes-sim-core.d.ts",
    "src/washes-sim-worker.js",
    "src/washes-worker-backend.js",
    "src/washes-state-codec.js",
    "src/shaders/brush_stamp.frag",
    "dist/washes.standalone.js",
    "dist/washes-timeline.standalone.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CITATION.cff"
  ],
  "keywords": [
    "watercolor",
    "simulation",
    "fluid",
    "canvas",
    "webgl",
    "gpu",
    "kubelka-munk",
    "generative",
    "creative-coding",
    "visualization",
    "svg",
    "animation"
  ],
  "author": "Stephanie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/castavridis/washes-js"
  },
  "homepage": "https://github.com/castavridis/washes-js#readme",
  "bugs": {
    "url": "https://github.com/castavridis/washes-js/issues"
  },
  "scripts": {
    "test": "node tests/washes-test-harness.cjs src/washes.js all",
    "test:texture-parity": "node tests/texture-parity.test.mjs",
    "test:api": "node tests/api-surface.test.mjs",
    "test:gpu-sync": "node tests/gpu-sync.test.cjs",
    "test:headless": "node tests/headless-bare.test.mjs",
    "sync:gpu": "node scripts/sync-gpu.cjs",
    "assemble": "node scripts/assemble.cjs",
    "test:browser": "playwright test",
    "build": "node scripts/build-standalone.cjs",
    "prepublishOnly": "node scripts/sync-gpu.cjs --check && node scripts/build-standalone.cjs && npm test && npm run test:texture-parity && npm run test:api && npm run test:gpu-sync && npm run test:headless",
    "test:sim-core": "node tests/sim-core-standalone.test.mjs",
    "test:worker": "node tests/worker-backend.test.mjs",
    "test:save-load": "node tests/save-load.test.mjs"
  },
  "sideEffects": [
    "./src/washes.js",
    "./src/washes-gpu-sim.js",
    "./src/index.js"
  ],
  "engines": {
    "node": ">=18"
  }
}
